{
  "display_properties": [
    "choix",
    "groupe",
    "distance",
    "azimut",
    "cd_nom",
    "effectif_alim",
    "effectif_repos",
    "effectif_total",
    "activite",
    "nombre",
    "comments"
  ],
  "display_list": [
    "choix",
    "cd_nom",
    "activite"
  ],
  "specific": {
    "choix": {
      "type_widget": "nomenclature",
      "required": true,
      "attribut_label": "Type d'observation",
      "code_nomenclature_type": "TYPE_OBSERVATION",
      "type_util": "nomenclature"
    },
    "groupe": {
      "type_widget": "number",
      "attribut_label": "Groupe",
      "required": true
    },
    "cd_nom": {
      "hidden": false,
      "required": "({value, meta}) => (meta.nomenclatures[value.choix] || {}).cd_nomenclature == 'Limicole'"
    },
    "activite": {
      "type_widget": "nomenclature",
      "required": "({value, meta}) => (meta.nomenclatures[value.choix] || {}).cd_nomenclature == 'ActiviteHumaine'",
      "hidden": false,
      "attribut_label": "Activité",
      "code_nomenclature_type": "ACTIVITE_HUMAINE",
      "type_util": "nomenclature"
    },
    "distance": {
      "type_widget": "number",
      "attribut_label": "Distance",
      "required": true,
      "min": 0
    },
    "azimut": {
      "type_widget": "number",
      "attribut_label": "Azimut",
      "min": 0,
      "max": 360,
      "required": true
    },
    "effectif_alim": {
      "type_widget": "number",
      "attribut_label": "Effectif en alimentation",
      "hidden": false,
      "required": "({value, meta}) => (meta.nomenclatures[value.choix] || {}).cd_nomenclature == 'Limicole'"
    },
    "effectif_repos": {
      "type_widget": "number",
      "attribut_label": "Effectif au repos",
      "hidden": false,
      "required": "({value, meta}) => (meta.nomenclatures[value.choix] || {}).cd_nomenclature == 'Limicole'"
    },
    "effectif_total": {
      "type_widget": "number",
      "attribut_label": "Effectif total"
    },
    "nombre": {
      "type_widget": "number",
      "attribut_label": "Nombre",
      "required": "({value, meta}) => (meta.nomenclatures[value.choix] || {}).cd_nomenclature == 'ActiviteHumaine'",
      "hidden": false
    },
    "comments": {
      "attribute_label": "Commentaire"
    }
  },
  "change": [
      "({objForm, meta}) => {",
      "const choixCd = (meta.nomenclatures[objForm.value.choix] || {}).cd_nomenclature;",
      "const effectif_total = objForm.value.effectif_repos + objForm.value.effectif_alim;",
      "if (choixCd == 'Limicole' && !objForm.controls.effectif_total.dirty) {",
      "objForm.patchValue({effectif_total})",
      "}",
      "const cd_nom = 0;",
      "if (choixCd == 'ActiviteHumaine') {",
      "objForm.patchValue({cd_nom})",
      "}",
      "let zero = {",
      "cd_nom: cd_nom,",
      "activite: null,",
      "effectif_alim: null,",
      "effectif_repos: null,",
      "effectif_total: null,",
      "nombre: null",
      "};",
      "if((!!objForm.old_choix) && (objForm.value.choix != objForm.old_choix)) {",
      "objForm.patchValue(zero)",
      "}",
      "objForm.old_choix = objForm.value.choix;",
      "}",
      ""
      ]
}
